        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^0.577.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.1",
        "zod": "^4.3.6",
        "zustand": "^5.0.11"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@tanstack/router-plugin": "^1.166.7",
        "@testing-library/jest-dom": "^6.9.1",
