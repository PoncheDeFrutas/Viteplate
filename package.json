{
    "name": "viteplate",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "check-types": "tsc -b --pretty false",
        "lint": "eslint .",
